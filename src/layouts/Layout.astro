---
import '../styles/global.css';

interface Props {
  title?: string;
  lang: string;
}

const { title = 'Gilles Gardet – CV', lang } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Curriculum vitae de Gilles Gardet, Lead Developer fullstack Java/Angular." />
    <title>{title}</title>
    <link rel="icon" type="image/jpeg" href="/assets/pictures/me.jpg" />
  </head>
  <body>
    <slot />
    <script>
      // Restore saved theme before first paint to avoid flash
      const saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </body>
</html>
